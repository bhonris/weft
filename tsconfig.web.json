{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "outDir": "./dist-types/web",
    "rootDir": "./src",
    "types": ["node", "vite/client"],
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@core/*": ["./src/core/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/renderer/**/*.ts", "src/renderer/**/*.tsx"],
  "exclude": ["**/*.test.ts", "**/*.spec.ts", "**/*.test.tsx", "**/*.spec.tsx"],
  "references": [{ "path": "./tsconfig.shared.json" }]
}
